# Core app settings
BASE_URL=https://your-app.example.com
HEADLESS=false
TIMEOUT_MS=30000
RESPONSE_STABLE_MS=1200
PLAYWRIGHT_BROWSER_CHANNEL=chrome
CAPTURE_NETWORK_CONTEXTS=true
CHAT_API_URL_CONTAINS=/chat|/message|/conversation
NETWORK_CONTEXT_URL_KEYWORD=/api/chat
TRACE_ALWAYS=false
PDF_REGISTRY_PATH=data/pdf_registry.json
APPEND_RUN_ID_TO_PROMPT=false

# Replace these placeholder selectors to match your chatbot UI
CHAT_WIDGET_BUTTON_SELECTOR=[data-testid="chat-widget-button"]
CHAT_IFRAME_SELECTOR=
CHAT_INPUT_SELECTOR=textarea[data-testid="chat-input"]
CHAT_SEND_BUTTON_SELECTOR=button[data-testid="chat-send"]
BOT_MESSAGE_SELECTOR=[data-testid="bot-message"]
USER_MESSAGE_SELECTOR=[data-testid="user-message"]
CHAT_STREAMING_INDICATOR_SELECTOR=[data-testid="chat-streaming"]
CHAT_CITATION_SELECTOR=[data-testid="chat-citation"]

# DSPy / RAGAS thresholds
DSPY_MIN_SCORE=0.70
DSPY_KEYWORD_THRESHOLD=1.0
DSPY_FALLBACK_THRESHOLD=1.0
DSPY_FORMAT_THRESHOLD=1.0
DSPY_PDF_GROUNDING_THRESHOLD=1.0
RAGAS_ANSWER_RELEVANCY_THRESHOLD=0.65
RAGAS_ANSWER_RELEVANCY_STRICTNESS=3
RAGAS_ANSWER_ACCURACY_THRESHOLD=0.70
RAGAS_FAITHFULNESS_THRESHOLD=0.70
RAGAS_CONTEXT_RELEVANCE_THRESHOLD=0.70
RAGAS_RESPONSE_GROUNDEDNESS_THRESHOLD=0.70
RAGAS_CONTEXT_PRECISION_THRESHOLD=0.70
RAGAS_CONTEXT_UTILIZATION_THRESHOLD=0.70
RAGAS_CONTEXT_RECALL_THRESHOLD=0.70
RAGAS_CONTEXT_ENTITY_RECALL_THRESHOLD=0.70
RAGAS_NOISE_SENSITIVITY_RELEVANT_THRESHOLD=0.30
RAGAS_NOISE_SENSITIVITY_IRRELEVANT_THRESHOLD=0.30

# Evaluation provider switch
# Recommended default for this repo: `openai` (including Azure OpenAI-compatible endpoints).
# Keep the chat + embedding model names aligned with the enterprise repo where possible.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
RAGAS_METRICS_PROFILE=fast
RAGAS_SKIP_LLM_METRICS_IF_NO_KEY=true

# Backward-compatible optional providers
EVALUATOR_PROVIDER=ollama
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
