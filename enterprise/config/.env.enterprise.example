# Enterprise UI target
BASE_URL=https://<your-enterprise-chatbot-url>
HEADLESS=false
TIMEOUT_MS=45000
RESPONSE_STABLE_MS=1500
PLAYWRIGHT_BROWSER_CHANNEL=chrome
CAPTURE_NETWORK_CONTEXTS=true
CHAT_API_URL_CONTAINS=/chat|/message|/conversation|/api
NETWORK_CONTEXT_URL_KEYWORD=/api
TRACE_ALWAYS=false
PDF_REGISTRY_PATH=data/pdf_registry.json
APPEND_RUN_ID_TO_PROMPT=false

# Chatbot UI selectors
CHAT_WIDGET_BUTTON_SELECTOR=
CHAT_IFRAME_SELECTOR=
CHAT_INPUT_SELECTOR=
CHAT_SEND_BUTTON_SELECTOR=
BOT_MESSAGE_SELECTOR=
USER_MESSAGE_SELECTOR=
CHAT_STREAMING_INDICATOR_SELECTOR=
CHAT_CITATION_SELECTOR=

# Provider and model settings
LLM_PROVIDER=azure_openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=https://<your-resource>.openai.azure.com/openai/v1
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
RAGAS_METRICS_PROFILE=fast
RAGAS_SKIP_LLM_METRICS_IF_NO_KEY=true

# Enterprise retrieval / orchestration placeholders
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_INDEX_NAME=playready-kb-index
AZURE_SEARCH_SEMANTIC_CONFIG=default
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api/projects/<project-name>
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_USE_MANAGED_IDENTITY=true
AZURE_USE_SERVICE_PRINCIPAL=false
