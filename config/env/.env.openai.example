# Repo 1: Local / QA Evaluation profile (OpenAI or Azure OpenAI-compatible endpoint)
LLM_PROVIDER=openai
OPENAI_API_KEY=<set-in-your-shell-or-secret-store>
OPENAI_BASE_URL=https://<your-openai-compatible-endpoint>/openai/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAGAS_METRICS_PROFILE=fast
RAGAS_SKIP_LLM_METRICS_IF_NO_KEY=true

# Optional Azure-style aliases if you want the same deployment names used by the enterprise repo
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
